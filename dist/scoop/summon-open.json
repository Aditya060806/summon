{
	"version": "1.1.2",
	"description": "Open URLs, files, folders, and apps from one cross-platform command",
	"homepage": "https://github.com/Aditya060806/summon",
	"license": "MIT",
	"depends": "nodejs",
	"installer": {
		"script": "npm install -g summon-open@1.1.2"
	},
	"uninstaller": {
		"script": "npm uninstall -g summon-open"
	},
	"checkver": {
		"url": "https://registry.npmjs.org/summon-open/latest",
		"jsonpath": "$.version"
	},
	"autoupdate": {
		"installer": {
			"script": "npm install -g summon-open@$version"
		}
	}
}
